{
  "name": "revpilot-hotel-revenue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/postbuild.mjs && node scripts/verify-seo.mjs",
    "preview": "vite preview",
    "generate:data": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/generateSyntheticData.ts",
    "test": "vitest run && node --test server/utils.test.mjs server/pms/normalize.test.mjs server/notifications/delivery.test.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
