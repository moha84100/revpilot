# Serveur local
VOICE_PORT=4180
PUBLIC_BASE_URL=https://votre-domaine-public.fr

# OpenAI Realtime — ne jamais exposer cette clé dans le navigateur
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Twilio — nécessaire uniquement pour recevoir de vrais appels
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Numéro réel de la réception pour le transfert humain
RECEPTION_PHONE_NUMBER=
