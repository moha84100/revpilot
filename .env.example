# Copier ce fichier sous le nom .env.local puis remplacer les valeurs.
# Ne jamais publier .env.local ni envoyer ces clés dans le navigateur.

TICKETMASTER_API_KEY=
PREDICTHQ_TOKEN=
OPENAGENDA_API_KEY=

# Identifiants des agendas OpenAgenda locaux, séparés par des virgules.
OPENAGENDA_AGENDA_UIDS=

# Connexion PMS Mews (lecture seule)
MEWS_ENVIRONMENT=demo
MEWS_CLIENT_TOKEN=
MEWS_ACCESS_TOKEN=
MEWS_SERVICE_ID=
MEWS_ROOM_COUNT=
MEWS_DEFAULT_ROOM_RATE=110

# Notifications réelles via Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=RevPilot
BREVO_SMS_SENDER=RevPilot
BREVO_WHATSAPP_SENDER_NUMBER=
